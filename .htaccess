<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /Nestle_NDRC-/

    # 1. Stop if the request already points to public/
    RewriteCond %{REQUEST_URI} ^/Nestle_NDRC-/public/ [NC]
    RewriteRule ^ - [L]

    # 2. Rewrite root/index requests to public/
    RewriteRule ^$ public/index.php [L]
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
